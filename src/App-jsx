import React from "react";
import { BrowserRouter, Routes, Route } from "react-router-dom";

import Login from "./pages/login";
import Home from "./pages/home";
import ListaBarbeiros from "./pages/listaBarbeiros";
import PerfilBarbeiro from "./pages/perfilBarbeiro";
import ServiceSelector from "./pages/serviceSelector";
import ConfirmarAgendamento from "./pages/confirmarAgendamento";

export default function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route path="/" element={<Login />} />
        <Route path="/home" element={<Home />} />
        <Route path="/lista-barbeiros" element={<ListaBarbeiros />} />
        <Route path="/perfil-barbeiro/:barberId" element={<PerfilBarbeiro />} />
        
        {/* Tela de seleção de serviços */}
        <Route path="/servicos/:barberId" element={<ServiceSelector />} />

        {/* Tela de confirmar agendamento */}
        <Route
          path="/confirmar-agendamento/:barberId/:serviceId"
          element={<ConfirmarAgendamento />}
        />
      </Routes>
    </BrowserRouter>
  );
}
